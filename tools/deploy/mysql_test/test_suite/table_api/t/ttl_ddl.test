# 关闭并行建表
alter system set _enable_parallel_table_creation = false;
--disable_warnings
drop table if exists test_idx$cf7;
--enable_warnings
CREATE TABLE test_idx$cf7 (
  K VARBINARY(1024), 
  Q VARBINARY(256), 
  T BIGINT, 
  V VARBINARY(1048576) NOT NULL, 
  PRIMARY KEY(K, Q, T),
  index idx(K, Q, T) local)
KV_ATTRIBUTES ='{"Hbase": {"TimeToLive": 3600, "MaxVersions": 3}, "TTLScanIndex": "idx"}'
PARTITION BY KEY(K) PARTITIONS 3;
set _show_ddl_in_compat_mode = 1;
show create table test_idx$cf7;
set _show_ddl_in_compat_mode = 0;
show create table test_idx$cf7;
drop table test_idx$cf7;

# 开启并行建表, 默认即开启
alter system set _enable_parallel_table_creation = true;
--disable_warnings
drop table if exists test_idx$cf7;
--enable_warnings
CREATE TABLE test_idx$cf7 (
  K VARBINARY(1024), 
  Q VARBINARY(256), 
  T BIGINT, 
  V VARBINARY(1048576) NOT NULL, 
  PRIMARY KEY(K, Q, T),
  index idx(K, Q, T) local)
KV_ATTRIBUTES ='{"Hbase": {"TimeToLive": 3600, "MaxVersions": 3}, "TTLScanIndex": "idx"}'
PARTITION BY KEY(K) PARTITIONS 3;
set _show_ddl_in_compat_mode = 1;
show create table test_idx$cf7;
set _show_ddl_in_compat_mode = 0;
show create table test_idx$cf7;
drop table test_idx$cf7;

