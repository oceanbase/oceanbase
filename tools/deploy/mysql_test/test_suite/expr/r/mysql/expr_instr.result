============================================================
=== design supplement: type conversion edge cases ==========
============================================================
# DECIMAL implicit conversion with pos/occ
select instr(123.456, '3.', 1, 1) from dual;
+----------------------------+
| instr(123.456, '3.', 1, 1) |
+----------------------------+
|                          3 |
+----------------------------+
select instr(123.456, 123.4, 1, 1) from dual;
+-----------------------------+
| instr(123.456, 123.4, 1, 1) |
+-----------------------------+
|                           1 |
+-----------------------------+
select instr(1.999999999, 9999, 1, 1) from dual;
+--------------------------------+
| instr(1.999999999, 9999, 1, 1) |
+--------------------------------+
|                              3 |
+--------------------------------+

# DATE type with 4-arg
select instr(cast('2023-01-15' as date), '2023', 1, 1) from dual;
+-------------------------------------------------+
| instr(cast('2023-01-15' as date), '2023', 1, 1) |
+-------------------------------------------------+
|                                               1 |
+-------------------------------------------------+

# BINARY / hex
select instr(0x414243, 0x42, 1, 1) from dual;
+-----------------------------+
| instr(0x414243, 0x42, 1, 1) |
+-----------------------------+
|                           2 |
+-----------------------------+
select instr(cast('abc' as binary), cast('b' as binary), 1, 1) from dual;
+---------------------------------------------------------+
| instr(cast('abc' as binary), cast('b' as binary), 1, 1) |
+---------------------------------------------------------+
|                                                       2 |
+---------------------------------------------------------+

# Number implicit with negative pos
select instr(12345, '23', -1, 1) from dual;
+---------------------------+
| instr(12345, '23', -1, 1) |
+---------------------------+
|                         2 |
+---------------------------+
select instr(12345, 23, -1, 1) from dual;
+-------------------------+
| instr(12345, 23, -1, 1) |
+-------------------------+
|                       2 |
+-------------------------+

