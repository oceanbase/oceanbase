drop table test;
================ complex test cases for instr with position and occurrence ================
drop table if exists t_instr_test;
create table t_instr_test (
  id int primary key,
  str_col varchar(100),
  pattern_col varchar(50),
  pos_col int,
  occ_col int
);

insert into t_instr_test values
(1, 'foobarbar', 'bar', 1, 1),
(2, 'foobarbar', 'bar', 4, 1),
(3, 'foobarbar', 'bar', 1, 2),
(4, 'abcabcabc', 'abc', 1, 1),
(5, 'abcabcabc', 'abc', 1, 2),
(6, 'abcabcabc', 'abc', 1, 3),
(7, 'abcabcabc', 'abc', 4, 1),
(8, '阿里巴巴巴巴', '巴巴', 1, 1),
(9, '阿里巴巴巴巴', '巴巴', 1, 2),
(10, 'abcdef', 'c', -1, 1);

select id, instr(str_col, pattern_col) as result from t_instr_test order by id;
+----+--------+
| id | result |
+----+--------+
|  1 |      4 |
|  2 |      4 |
|  3 |      4 |
|  4 |      1 |
|  5 |      1 |
|  6 |      1 |
|  7 |      1 |
|  8 |      3 |
|  9 |      3 |
| 10 |      3 |
+----+--------+
select id, instr(str_col, pattern_col, pos_col) as result from t_instr_test where pos_col > 0 order by id;
+----+--------+
| id | result |
+----+--------+
|  1 |      4 |
|  2 |      4 |
|  3 |      4 |
|  4 |      1 |
|  5 |      1 |
|  6 |      1 |
|  7 |      4 |
|  8 |      3 |
|  9 |      3 |
+----+--------+
select id, instr(str_col, pattern_col, pos_col, occ_col) as result from t_instr_test order by id;
+----+--------+
| id | result |
+----+--------+
|  1 |      4 |
|  2 |      4 |
|  3 |      7 |
|  4 |      1 |
|  5 |      4 |
|  6 |      7 |
|  7 |      4 |
|  8 |      3 |
|  9 |      4 |
| 10 |      3 |
+----+--------+

select instr(concat('foo', 'barbar'), 'bar', 1 + 2, 2 - 1) as expr_test1;
+------------+
| expr_test1 |
+------------+
|          4 |
+------------+
select instr(repeat('ab', 5), 'ab', 3, 2) as expr_test2;
+------------+
| expr_test2 |
+------------+
|          5 |
+------------+
select instr(upper('foobarbar'), 'BAR', 1, 1) as expr_test3;
+------------+
| expr_test3 |
+------------+
|          4 |
+------------+
select instr(lower('FOOBARBAR'), 'bar', 1, 2) as expr_test4;
+------------+
| expr_test4 |
+------------+
|          7 |
+------------+
select instr(lpad('abc', 10, 'x'), 'abc', 1, 1) as expr_test5;
+------------+
| expr_test5 |
+------------+
|          8 |
+------------+
select instr(rpad('abc', 10, 'x'), 'xxx', 1, 1) as expr_test6;
+------------+
| expr_test6 |
+------------+
|          4 |
+------------+

select instr(substr('foobarbar', 1, 6), 'bar', 1, 1) as nested_test1;
+--------------+
| nested_test1 |
+--------------+
|            4 |
+--------------+
select instr(replace('fooXXXbar', 'XXX', 'bar'), 'bar', 1, 2) as nested_test2;
+--------------+
| nested_test2 |
+--------------+
|            7 |
+--------------+
select substr('foobarbar', instr('foobarbar', 'bar', 1, 1), 3) as nested_test3;
+--------------+
| nested_test3 |
+--------------+
| bar          |
+--------------+
select substr('foobarbar', instr('foobarbar', 'bar', 1, 2), 3) as nested_test4;
+--------------+
| nested_test4 |
+--------------+
| bar          |
+--------------+

select instr('foobarbar', 'bar',
  case when 1=1 then 1 else 4 end,
  case when 2=2 then 2 else 1 end) as case_test1;
+------------+
| case_test1 |
+------------+
|          7 |
+------------+
select instr('abcabc', 'a',
  case when id > 5 then -1 else 1 end, 1) as case_test2
from t_instr_test where id = 10;
+------------+
| case_test2 |
+------------+
|          4 |
+------------+

select max(instr(str_col, pattern_col, 1, 1)) as max_result from t_instr_test;
+------------+
| max_result |
+------------+
|          4 |
+------------+
select min(instr(str_col, pattern_col, 1, 1)) as min_result from t_instr_test;
+------------+
| min_result |
+------------+
|          1 |
+------------+
select sum(instr(str_col, pattern_col, 1, 1)) as sum_result from t_instr_test where instr(str_col, pattern_col, 1, 1) > 0;
+------------+
| sum_result |
+------------+
|         25 |
+------------+
select avg(instr(str_col, pattern_col, 1, 1)) as avg_result from t_instr_test;
+------------+
| avg_result |
+------------+
|     2.5000 |
+------------+

select pos_col, count(*) as cnt, sum(instr(str_col, pattern_col, pos_col, occ_col)) as sum_instr
from t_instr_test where pos_col > 0 group by pos_col order by pos_col;
+---------+------+-----------+
| pos_col | cnt  | sum_instr |
+---------+------+-----------+
|       1 |    7 |        30 |
|       4 |    2 |         8 |
+---------+------+-----------+

select pos_col, count(*) as cnt
from t_instr_test
group by pos_col
having sum(instr(str_col, pattern_col, pos_col, occ_col)) > 3
order by pos_col;
+---------+------+
| pos_col | cnt  |
+---------+------+
|       1 |    7 |
|       4 |    2 |
+---------+------+

select id, str_col from t_instr_test where instr(str_col, pattern_col, 1, 1) > 0 order by id;
