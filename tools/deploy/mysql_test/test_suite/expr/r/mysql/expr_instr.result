=== design supplement: CAST return value ===================
============================================================
select cast(instr('foobarbar', 'bar', 1, 2) as signed) from dual;
+-------------------------------------------------+
| cast(instr('foobarbar', 'bar', 1, 2) as signed) |
+-------------------------------------------------+
|                                               7 |
+-------------------------------------------------+
select cast(instr('foobarbar', 'bar', 1, 2) as char) from dual;
+-----------------------------------------------+
| cast(instr('foobarbar', 'bar', 1, 2) as char) |
+-----------------------------------------------+
| 7                                             |
+-----------------------------------------------+
select cast(instr('foobarbar', 'bar', 1, 2) as decimal(10,2)) from dual;
