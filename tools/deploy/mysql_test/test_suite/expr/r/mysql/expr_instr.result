| cast(instr('foobarbar', 'bar', 1, 2) as decimal(10,2)) |
+--------------------------------------------------------+
|                                                   7.00 |
+--------------------------------------------------------+

============================================================
=== design supplement: correlation functions ==============
============================================================
select instr(user(), 't') from dual;
+--------------------+
| instr(user(), 't') |
+--------------------+
|                  0 |
+--------------------+
select instr(version(), '.', 1, 2) from dual;
+-----------------------------+
| instr(version(), '.', 1, 2) |
+-----------------------------+
|                           4 |
+-----------------------------+
select instr(user(), user(), 1, 1) from dual;
+-----------------------------+
| instr(user(), user(), 1, 1) |
+-----------------------------+
|                           1 |
+-----------------------------+

============================================================
=== design supplement: DECODE-style / IF extended =========
============================================================
select if(instr('abcabc', 'bc', 1, 1) > 0, 'found_first', 'missing') from dual;
+---------------------------------------------------------------+
| if(instr('abcabc', 'bc', 1, 1) > 0, 'found_first', 'missing') |
+---------------------------------------------------------------+
| found_first                                                   |
+---------------------------------------------------------------+
select if(instr('abcabc', 'bc', 1, 2) > 0, 'found_second', 'missing') from dual;
+----------------------------------------------------------------+
| if(instr('abcabc', 'bc', 1, 2) > 0, 'found_second', 'missing') |
+----------------------------------------------------------------+
| found_second                                                   |
+----------------------------------------------------------------+
select if(instr('abcabc', 'bc', 1, 3) > 0, 'found_third', 'missing') from dual;
+---------------------------------------------------------------+
| if(instr('abcabc', 'bc', 1, 3) > 0, 'found_third', 'missing') |
+---------------------------------------------------------------+
| missing                                                       |
+---------------------------------------------------------------+

select count(*) from (
  select case
    when instr(str_col, pattern_col, 1, 1) = 0 then 'zero'
    when instr(str_col, pattern_col, 1, 2) = 0 then 'one'
    else 'multiple'
  end as flag
  from t_instr_test where id <= 6
) v where flag in ('zero', 'one', 'multiple');
+----------+
| count(*) |
+----------+
|        6 |
+----------+

============================================================
=== design supplement: multiple instr calls in one row =====
============================================================
select instr('foobarbar', 'bar', 1, 1) as r1,
       instr('foobarbar', 'bar', 1, 2) as r2,
       instr('foobarbar', 'bar', 4, 1) as r3
from dual;
+----+----+----+
| r1 | r2 | r3 |
+----+----+----+
|  4 |  7 |  4 |
+----+----+----+

select count(*) from t_instr_test
  where instr(str_col, pattern_col, 1, 1) <
        instr(str_col, pattern_col, 1, 2);
+----------+
| count(*) |
+----------+
|       11 |
+----------+

select count(*) from t_instr_test
  where instr(str_col, pattern_col, 1, 1) > 0
    and instr(str_col, pattern_col, pos_col, occ_col) > 0;
+----------+
| count(*) |
+----------+
|       10 |
+----------+

============================================================
=== design supplement: special character patterns ==========
============================================================
# Percent and underscore (non-wildcard in INSTR)
select instr('abc%def', '%', 1, 1) from dual;
+-----------------------------+
| instr('abc%def', '%', 1, 1) |
+-----------------------------+
|                           4 |
+-----------------------------+
select instr('abc_def', '_', 1, 1) from dual;
+-----------------------------+
| instr('abc_def', '_', 1, 1) |
+-----------------------------+
|                           4 |
+-----------------------------+
# Backslash
select instr('a\\b\\c', '\\\\', 1, 2) from dual;
+--------------------------------+
| instr('a\\b\\c', '\\\\', 1, 2) |
+--------------------------------+
|                              0 |
+--------------------------------+
# Quotes
select instr('it''s a test', '''', 1, 1) from dual;
+-----------------------------------+
| instr('it''s a test', '''', 1, 1) |
+-----------------------------------+
|                                 3 |
+-----------------------------------+
# Double quotes
select instr('say "hello"', '"', 1, 2) from dual;
+---------------------------------+
| instr('say "hello"', '"', 1, 2) |
+---------------------------------+
|                              11 |
+---------------------------------+
============================================================
=== implementation analysis: occ <= 0 returns 0 (not error)=
============================================================
# MySQL mode: occ <= 0 returns 0 instead of error
SELECT INSTR('abc', 'a', 1, 0);
+-------------------------+
| INSTR('abc', 'a', 1, 0) |
+-------------------------+
|                       0 |
+-------------------------+
SELECT INSTR('abc', 'a', 1, -1);
+--------------------------+
| INSTR('abc', 'a', 1, -1) |
+--------------------------+
|                        0 |
+--------------------------+
SELECT INSTR('abc', 'a', 1, -999);
+----------------------------+
| INSTR('abc', 'a', 1, -999) |
+----------------------------+
|                          0 |
+----------------------------+
SELECT INSTR('abcdef', 'a', -1, 0);
+-----------------------------+
| INSTR('abcdef', 'a', -1, 0) |
+-----------------------------+
|                           0 |
+-----------------------------+
SELECT INSTR('abcdef', 'a', -1, -5);
+------------------------------+
| INSTR('abcdef', 'a', -1, -5) |
+------------------------------+
|                            0 |
+------------------------------+

============================================================
=== implementation analysis: pos == 0 returns 0 ============
============================================================
# MySQL mode: pos = 0 returns 0
SELECT INSTR('abc', 'a', 0);
+----------------------+
| INSTR('abc', 'a', 0) |
+----------------------+
|                    0 |
+----------------------+
SELECT INSTR('abc', 'a', 0, 1);
+-------------------------+
| INSTR('abc', 'a', 0, 1) |
+-------------------------+
|                       0 |
+-------------------------+
SELECT INSTR('abc', 'a', 0, 2);
+-------------------------+
| INSTR('abc', 'a', 0, 2) |
+-------------------------+
|                       0 |
+-------------------------+

============================================================
=== implementation analysis: empty needle ==================
============================================================
# Empty needle in MySQL mode
SELECT INSTR('abc', '');
+------------------+
| INSTR('abc', '') |
+------------------+
|                1 |
+------------------+
SELECT INSTR('abc', '', 1);
+---------------------+
| INSTR('abc', '', 1) |
+---------------------+
|                   1 |
+---------------------+
SELECT INSTR('abc', '', 1, 1);
+------------------------+
| INSTR('abc', '', 1, 1) |
+------------------------+
|                      1 |
+------------------------+
SELECT INSTR('abc', '', -1);
+----------------------+
| INSTR('abc', '', -1) |
+----------------------+
|                    3 |
+----------------------+
SELECT INSTR('', '');
+---------------+
| INSTR('', '') |
+---------------+
|             1 |
+---------------+
SELECT INSTR(NULL, '');
+-----------------+
| INSTR(NULL, '') |
+-----------------+
|            NULL |
+-----------------+

============================================================
=== implementation analysis: negative pos from end =========
============================================================
# Negative pos exactly at string boundaries
SELECT INSTR('abcdef', 'def', -1);
+----------------------------+
| INSTR('abcdef', 'def', -1) |
+----------------------------+
|                          4 |
+----------------------------+
SELECT INSTR('abcdef', 'def', -2);
+----------------------------+
| INSTR('abcdef', 'def', -2) |
+----------------------------+
|                          4 |
+----------------------------+
SELECT INSTR('abcdef', 'def', -3);
+----------------------------+
| INSTR('abcdef', 'def', -3) |
+----------------------------+
|                          4 |
+----------------------------+
SELECT INSTR('abcdef', 'def', -4);
+----------------------------+
| INSTR('abcdef', 'def', -4) |
+----------------------------+
|                          0 |
+----------------------------+
# Negative pos with occurrence
SELECT INSTR('abcabcabc', 'abc', -1);
+-------------------------------+
| INSTR('abcabcabc', 'abc', -1) |
+-------------------------------+
|                             7 |
+-------------------------------+
SELECT INSTR('abcabcabc', 'abc', -1, 2);
+----------------------------------+
| INSTR('abcabcabc', 'abc', -1, 2) |
+----------------------------------+
|                                4 |
+----------------------------------+
SELECT INSTR('abcabcabc', 'abc', -1, 3);
+----------------------------------+
| INSTR('abcabcabc', 'abc', -1, 3) |
+----------------------------------+
|                                1 |
+----------------------------------+
SELECT INSTR('abcabcabc', 'abc', -3, 2);
+----------------------------------+
| INSTR('abcabcabc', 'abc', -3, 2) |
+----------------------------------+
|                                4 |
+----------------------------------+
# Single char
SELECT INSTR('a', 'a', -1);
+---------------------+
| INSTR('a', 'a', -1) |
+---------------------+
|                   1 |
+---------------------+
SELECT INSTR('abc', 'c', -1);
+-----------------------+
| INSTR('abc', 'c', -1) |
+-----------------------+
|                     3 |
+-----------------------+
SELECT INSTR('abc', 'c', -1, 2);
+--------------------------+
| INSTR('abc', 'c', -1, 2) |
+--------------------------+
|                        0 |
+--------------------------+

============================================================
=== implementation analysis: multi-byte negative pos =======
============================================================
# CJK with negative position
SELECT INSTR('你好世界', '世界', -1);
+-------------------------------------+
| INSTR('你好世界', '世界', -1)       |
+-------------------------------------+
|                                   3 |
+-------------------------------------+
SELECT INSTR('你好世界', '世界', -2);
+-------------------------------------+
| INSTR('你好世界', '世界', -2)       |
+-------------------------------------+
|                                   3 |
+-------------------------------------+
SELECT INSTR('你好世界你好', '你好', -1);
+-------------------------------------------+
| INSTR('你好世界你好', '你好', -1)         |
+-------------------------------------------+
|                                         5 |
+-------------------------------------------+
SELECT INSTR('你好世界你好', '你好', -2);
+-------------------------------------------+
| INSTR('你好世界你好', '你好', -2)         |
+-------------------------------------------+
|                                         5 |
+-------------------------------------------+
SELECT INSTR('你好世界你好', '你好', -3);
+-------------------------------------------+
| INSTR('你好世界你好', '你好', -3)         |
+-------------------------------------------+
|                                         1 |
+-------------------------------------------+
SELECT INSTR('你好世界你好', '你好', -1, 2);
+----------------------------------------------+
| INSTR('你好世界你好', '你好', -1, 2)         |
+----------------------------------------------+
|                                            1 |
+----------------------------------------------+
# Emoji with negative position
SELECT INSTR('ab🎉cd🎉ef', '🎉', -1);
+-------------------------------------+
| INSTR('ab🎉cd🎉ef', '🎉', -1)             |
+-------------------------------------+
|                                   6 |
+-------------------------------------+
SELECT INSTR('ab🎉cd🎉ef', '🎉', -1, 2);
+----------------------------------------+
| INSTR('ab🎉cd🎉ef', '🎉', -1, 2)             |
+----------------------------------------+
|                                      3 |
+----------------------------------------+
SELECT INSTR('🎉🎊🎉🎊', '🎊', -1);
+---------------------------------------+
| INSTR('🎉🎊🎉🎊', '🎊', -1)                     |
+---------------------------------------+
|                                     4 |
+---------------------------------------+
SELECT INSTR('🎉🎊🎉🎊', '🎊', -1, 2);
+------------------------------------------+
| INSTR('🎉🎊🎉🎊', '🎊', -1, 2)                     |
+------------------------------------------+
|                                        3 |
+------------------------------------------+

============================================================
=== implementation analysis: byte/char alignment risk ======
============================================================
# Needle found at byte offset that is not char-aligned
SELECT INSTR('a中b国c', '中', 1);
+------------------------------+
| INSTR('a中b国c', '中', 1)    |
+------------------------------+
|                            2 |
+------------------------------+
SELECT INSTR('a中b国c', '中', 2);
+------------------------------+
| INSTR('a中b国c', '中', 2)    |
+------------------------------+
|                            2 |
+------------------------------+
SELECT INSTR('a中b国c', '国', -1);
+-------------------------------+
| INSTR('a中b国c', '国', -1)    |
+-------------------------------+
|                             4 |
+-------------------------------+
SELECT INSTR('中a国b', 'a', 1);
+---------------------------+
| INSTR('中a国b', 'a', 1)   |
+---------------------------+
|                         2 |
+---------------------------+
SELECT INSTR('中a国b', 'b', -1);
+----------------------------+
| INSTR('中a国b', 'b', -1)   |
+----------------------------+
|                          4 |
+----------------------------+
# ASCII needle in multi-byte haystack with negative pos
SELECT INSTR('a中b国c', 'b', -1);
+-----------------------------+
| INSTR('a中b国c', 'b', -1)   |
+-----------------------------+
|                           3 |
+-----------------------------+
SELECT INSTR('a中b国c中d', '中', -1);
+-----------------------------------+
| INSTR('a中b国c中d', '中', -1)     |
+-----------------------------------+
|                                 6 |
+-----------------------------------+
SELECT INSTR('a中b国c中d', '中', -1, 2);
+--------------------------------------+
| INSTR('a中b国c中d', '中', -1, 2)     |
+--------------------------------------+
|                                    2 |
+--------------------------------------+

============================================================
=== implementation analysis: very large position values ====
============================================================
# Position far beyond haystack length
SELECT INSTR('abc', 'a', 99999999);
+-----------------------------+
| INSTR('abc', 'a', 99999999) |
+-----------------------------+
|                           0 |
+-----------------------------+
SELECT INSTR('abc', 'a', 99999999, 1);
+--------------------------------+
| INSTR('abc', 'a', 99999999, 1) |
+--------------------------------+
|                              0 |
+--------------------------------+
SELECT INSTR('abc', 'a', -99999999);
+------------------------------+
| INSTR('abc', 'a', -99999999) |
+------------------------------+
|                            0 |
+------------------------------+
SELECT INSTR('abc', 'a', -99999999, 1);
+---------------------------------+
| INSTR('abc', 'a', -99999999, 1) |
+---------------------------------+
|                               0 |
+---------------------------------+
# Occurrence far beyond actual count
SELECT INSTR('abcabc', 'a', 1, 999);
+------------------------------+
| INSTR('abcabc', 'a', 1, 999) |
+------------------------------+
|                            0 |
+------------------------------+
SELECT INSTR('abcabc', 'a', -1, 999);
+-------------------------------+
| INSTR('abcabc', 'a', -1, 999) |
+-------------------------------+
|                             0 |
+-------------------------------+

============================================================
=== implementation analysis: BINARY / NUL byte search ======
============================================================
# Search for NUL byte
SELECT INSTR(CONCAT('a', CHAR(0), 'b'), CHAR(0));
+-------------------------------------------+
| INSTR(CONCAT('a', CHAR(0), 'b'), CHAR(0)) |
+-------------------------------------------+
|                                         2 |
+-------------------------------------------+
SELECT INSTR(CONCAT('a', CHAR(0), 'b', CHAR(0), 'c'), CHAR(0), 1, 2);
+---------------------------------------------------------------+
| INSTR(CONCAT('a', CHAR(0), 'b', CHAR(0), 'c'), CHAR(0), 1, 2) |
+---------------------------------------------------------------+
|                                                             4 |
+---------------------------------------------------------------+
SELECT INSTR(CONCAT('a', CHAR(0 USING ASCII), 'b'), CHAR(0 USING ASCII));
+-------------------------------------------------------------------+
| INSTR(CONCAT('a', CHAR(0 USING ASCII), 'b'), CHAR(0 USING ASCII)) |
+-------------------------------------------------------------------+
|                                                                 2 |
+-------------------------------------------------------------------+
# BINARY collation
SELECT INSTR(CAST('abc' AS BINARY), 'B');
+-----------------------------------+
| INSTR(CAST('abc' AS BINARY), 'B') |
+-----------------------------------+
|                                 0 |
+-----------------------------------+
SELECT INSTR(BINARY 'ABCabc', 'a');
+-----------------------------+
| INSTR(BINARY 'ABCabc', 'a') |
+-----------------------------+
|                           4 |
+-----------------------------+

============================================================
=== implementation analysis: TEXT/BLOB search ==============
============================================================
DROP TABLE IF EXISTS t_instr_text;
CREATE TABLE t_instr_text (id INT, content LONGTEXT);
INSERT INTO t_instr_text VALUES (1, CONCAT(REPEAT('x', 3000), 'TARGET', REPEAT('y', 3000)));
INSERT INTO t_instr_text VALUES (2, CONCAT(REPEAT('a', 2000), 'NEEDLE', REPEAT('b', 2000), 'NEEDLE'));
INSERT INTO t_instr_text VALUES (3, '');

# TEXT search across chunk boundary
SELECT id, INSTR(content, 'TARGET') FROM t_instr_text ORDER BY id;
+------+--------------------------+
| id   | INSTR(content, 'TARGET') |
+------+--------------------------+
|    1 |                     3001 |
|    2 |                        0 |
|    3 |                        0 |
+------+--------------------------+
SELECT id, INSTR(content, 'NEEDLE', 1, 2) FROM t_instr_text ORDER BY id;
+------+--------------------------------+
| id   | INSTR(content, 'NEEDLE', 1, 2) |
+------+--------------------------------+
|    1 |                              0 |
|    2 |                           4007 |
|    3 |                              0 |
+------+--------------------------------+
SELECT id, INSTR(content, 'NEEDLE', -1) FROM t_instr_text WHERE id = 2;
+------+------------------------------+
| id   | INSTR(content, 'NEEDLE', -1) |
+------+------------------------------+
|    2 |                         4007 |
+------+------------------------------+
SELECT id, INSTR(content, 'NEEDLE', -1, 2) FROM t_instr_text WHERE id = 2;
+------+---------------------------------+
| id   | INSTR(content, 'NEEDLE', -1, 2) |
+------+---------------------------------+
|    2 |                            2001 |
+------+---------------------------------+
# Empty TEXT
SELECT INSTR(content, 'x') FROM t_instr_text WHERE id = 3;
+---------------------+
| INSTR(content, 'x') |
+---------------------+
|                   0 |
+---------------------+

DROP TABLE t_instr_text;

============================================================
=== implementation analysis: edge case combinations ========
============================================================
# Overlapping needle matches
SELECT INSTR('aaaa', 'aa', 1, 1);
+---------------------------+
| INSTR('aaaa', 'aa', 1, 1) |
+---------------------------+
|                         1 |
+---------------------------+
SELECT INSTR('aaaa', 'aa', 1, 2);
+---------------------------+
| INSTR('aaaa', 'aa', 1, 2) |
+---------------------------+
|                         2 |
+---------------------------+
SELECT INSTR('aaaa', 'aa', 1, 3);
+---------------------------+
| INSTR('aaaa', 'aa', 1, 3) |
+---------------------------+
|                         3 |
+---------------------------+
SELECT INSTR('aaaa', 'aa', -1, 1);
+----------------------------+
| INSTR('aaaa', 'aa', -1, 1) |
+----------------------------+
|                          3 |
+----------------------------+
SELECT INSTR('aaaa', 'aa', -1, 2);
+----------------------------+
| INSTR('aaaa', 'aa', -1, 2) |
+----------------------------+
|                          2 |
+----------------------------+
# Haystack = needle
SELECT INSTR('abc', 'abc', 1);
+------------------------+
| INSTR('abc', 'abc', 1) |
+------------------------+
|                      1 |
+------------------------+
SELECT INSTR('abc', 'abc', 2);
+------------------------+
| INSTR('abc', 'abc', 2) |
+------------------------+
|                      0 |
+------------------------+
SELECT INSTR('abc', 'abc', -1);
+-------------------------+
| INSTR('abc', 'abc', -1) |
+-------------------------+
|                       1 |
+-------------------------+
# Needle appears at position 1
SELECT INSTR('abcabc', 'abc', 1, 1);
+------------------------------+
| INSTR('abcabc', 'abc', 1, 1) |
+------------------------------+
|                            1 |
+------------------------------+
SELECT INSTR('abcabc', 'abc', 1, 2);
+------------------------------+
| INSTR('abcabc', 'abc', 1, 2) |
+------------------------------+
|                            4 |
+------------------------------+

drop table t_instr_test;
