select instr('你好世界你好', '你好', 1, 2) as unicode_test2;
+---------------+
| unicode_test2 |
+---------------+
|             5 |
+---------------+
select instr('你好世界你好', '你好', -1, 1) as unicode_test3;
+---------------+
| unicode_test3 |
+---------------+
|             5 |
+---------------+
select instr('🎉🎊🎉🎈🎉', '🎉', 1, 1) as emoji_test1;
+-------------+
| emoji_test1 |
+-------------+
|           1 |
+-------------+
select instr('🎉🎊🎉🎈🎉', '🎉', 1, 2) as emoji_test2;
+-------------+
| emoji_test2 |
+-------------+
|           2 |
+-------------+
select instr('🎉🎊🎉🎈🎉', '🎉', 1, 3) as emoji_test3;
+-------------+
| emoji_test3 |
+-------------+
|           3 |
+-------------+

