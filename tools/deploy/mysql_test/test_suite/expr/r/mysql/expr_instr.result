| substr('foobarbar', instr('foobarbar', 'bar', 1, 1), instr('bar', 'r', 1, 1)) |
+-------------------------------------------------------------------------------+
| bar                                                                           |
+-------------------------------------------------------------------------------+
select left('foobarbar', instr('foobarbar', 'bar', 1, 1) + 2) from dual;
