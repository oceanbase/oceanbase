drop tenant if exists tenant1 force;
drop resource pool if exists pool_tenant1;
drop resource unit if exists test_unit;
CREATE RESOURCE UNIT test_unit MAX_CPU=1, MEMORY_SIZE='2G';
CREATE RESOURCE POOL pool_tenant1 UNIT test_unit, UNIT_NUM 1;
CREATE TENANT tenant1 RESOURCE_POOL_LIST=('pool_tenant1'), PRIMARY_ZONE='zone1', COMMENT='this is tenant1' SET ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
DESC DBA_OB_TENANTS;
Field	Type	Null	Key	Default	Extra
TENANT_ID	bigint(20)	NO		NULL	
TENANT_NAME	varchar(128)	NO		NULL	
TENANT_TYPE	varchar(4)	NO			
CREATE_TIME	timestamp(6)	YES			
MODIFY_TIME	timestamp(6)	YES			
PRIMARY_ZONE	varchar(8192)	YES		NULL	
LOCALITY	varchar(4096)	NO			
TABLEGROUP_NAME	varchar(128)	NO		NULL	
PREVIOUS_LOCALITY	varchar(4096)	NO			
COMPATIBILITY_MODE	varchar(6)	NO			
STATUS	varchar(64)	NO			
IN_RECYCLEBIN	varchar(3)	NO			
LOCKED	varchar(3)	NO		NULL	
TENANT_ROLE	varchar(100)	NO		NULL	
SWITCHOVER_STATUS	varchar(100)	NO		NULL	
SWITCHOVER_EPOCH	bigint(20)	NO		NULL	
SYNC_SCN	bigint(20) unsigned	NO		NULL	
REPLAYABLE_SCN	bigint(20) unsigned	NO		NULL	
READABLE_SCN	bigint(20) unsigned	NO		NULL	
RECOVERY_UNTIL_SCN	bigint(20) unsigned	NO			
LOG_MODE	varchar(100)	NO			
ARBITRATION_SERVICE_STATUS	varchar(64)	NO			
UNIT_NUM	bigint(20)	NO			
ZONE_UNIT_NUM_LIST	varchar(65536)	NO			
COMPATIBLE	varchar(65536)	NO			
MAX_LS_ID	bigint(20)	NO			
RESTORE_DATA_MODE	varchar(128)	NO			
FLASHBACK_LOG_SCN	bigint(20) unsigned	NO			
COMMENT	varchar(4096)	NO		NULL	
PROTECTION_MODE	varchar(128)	NO			
PROTECTION_LEVEL	varchar(128)	NO			
DEFAULT_TABLESPACE	varchar(30)	NO		NULL	
select TENANT_NAME, TENANT_TYPE, COMPATIBILITY_MODE, STATUS, IN_RECYCLEBIN, LOCKED, TENANT_ROLE, SWITCHOVER_STATUS, LOG_MODE, UNIT_NUM, RESTORE_DATA_MODE, COMMENT from DBA_OB_TENANTS where TENANT_NAME = 'tenant1';
TENANT_NAME	TENANT_TYPE	COMPATIBILITY_MODE	STATUS	IN_RECYCLEBIN	LOCKED	TENANT_ROLE	SWITCHOVER_STATUS	LOG_MODE	UNIT_NUM	RESTORE_DATA_MODE	COMMENT
tenant1	USER	MYSQL	NORMAL	NO	NO	PRIMARY	NORMAL	NOARCHIVELOG	1	NORMAL	this is tenant1
